modules = ["nodejs-20", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["unzip", "php82", "nano", "zip"]

[agent]
expertMode = true
stack = "FULLSTACK_JS"
integrations = ["javascript_object_storage:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
build = ["npm", "run", "build"]
run = ["node", "./dist/index.cjs"]
deploymentTarget = "autoscale"

[userenv]

[userenv.shared]
ADMIN_PASSWORD = "admin123"
ADMIN_EMAIL = "admin@carupa.com"

[userenv.development]

[userenv.production]

[objectStorage]
defaultBucketID = "replit-objstore-51ee15f4-ce30-49bc-a4a2-2d7fc848c244"
